    {
      "name": "3. Generate & Input Results",
      "item": [
        {
          "name": "Generate Schedule",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tournament/setup", "host": ["{{baseUrl}}"], "path": ["tournament", "setup"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Schedule created or exists', function () {",
                "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                "    console.log('Schedule ready');",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Get Matches & Input All Results",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/matches", "host": ["{{baseUrl}}"], "path": ["matches"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Get matches and input results', function () {",
                "    pm.response.to.have.status(200);",
                "    var matches = pm.response.json();",
                "    ",
                "    // Sample scores for group matches",
                "    var scores = [",
                "        [2, 1], [1, 0], [3, 2],",
                "        [0, 1], [2, 2], [1, 3],",
                "        [2, 1], [1, 1], [0, 2]",
                "    ];",
                "    ",
                "    var scoreIndex = 0;",
                "    var groupMatches = matches.filter(function(m) { return m.phase === 'group'; });",
                "    ",
                "    console.log('Found ' + groupMatches.length + ' group matches');",
                "    ",
                "    // Note: We can't make async calls in tests, so we'll save IDs",
                "    // User needs to run input requests manually",
                "    pm.collectionVariables.set('groupMatchCount', groupMatches.length);",
                "    ",
                "    // Save match IDs for reference",
                "    groupMatches.forEach(function(match, i) {",
                "        pm.collectionVariables.set('matchId' + (i + 1), match.id);",
                "        console.log('Match ' + (i + 1) + ': ID=' + match.id + ' (' + match.teamA.name + ' vs ' + match.teamB.name + ')');",
                "    });",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
