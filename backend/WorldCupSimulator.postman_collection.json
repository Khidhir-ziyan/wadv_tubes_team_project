    {
      "name": "6. Knockout & Bracket",
      "item": [
        {
          "name": "Get Standings",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/standings", "host": ["{{baseUrl}}"], "path": ["standings"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Standings loaded', function () {",
                "    pm.response.to.have.status(200);",
                "    var data = pm.response.json();",
                "    data.forEach(function(g) {",
                "        console.log('\\nGroup ' + g.group + ':');",
                "        g.standings.forEach(function(t, i) {",
                "            console.log((i+1) + '. ' + t.teamCode + ' - ' + t.points + ' pts');",
                "        });",
                "    });",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Advance to Knockout (Round of 16)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tournament/advance", "host": ["{{baseUrl}}"], "path": ["tournament", "advance"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Advanced to knockout', function () {",
                "    pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
                "    if (pm.response.code === 201) {",
                "        var data = pm.response.json();",
                "        console.log(data.message);",
                "        if (data.matches) {",
                "            pm.collectionVariables.set('knockoutMatchCount', data.matches.length);",
                "            console.log('Knockout matches created: ' + data.matches.length);",
                "        }",
                "    }",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Advance Next Round (QF → SF → Final)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tournament/advance-next-round", "host": ["{{baseUrl}}"], "path": ["tournament", "advance-next-round"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Advanced to next round', function () {",
                "    pm.expect(pm.response.code).to.be.oneOf([201, 409, 400]);",
                "    if (pm.response.code === 201) {",
                "        var data = pm.response.json();",
                "        console.log(data.message);",
                "    } else {",
                "        console.log(pm.response.json().error || 'Cannot advance');",
                "    }",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Input Final Result (3-1)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"scoreA\": 3,\n  \"scoreB\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/matches/{{finalMatchId}}/result", "host": ["{{baseUrl}}"], "path": ["matches", "{{finalMatchId}}", "result"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Final result saved', function () {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                "    if (pm.response.code === 200) {",
                "        var d = pm.response.json();",
                "        console.log('\\nFINAL: ' + d.teamA.name + ' ' + d.scoreA + '-' + d.scoreB + ' ' + d.teamB.name);",
                "    }",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Get Bracket & Champion",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/bracket", "host": ["{{baseUrl}}"], "path": ["bracket"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Bracket loaded', function () {",
                "    pm.response.to.have.status(200);",
                "    var b = pm.response.json();",
                "    ",
                "    function logRound(name, matches) {",
                "        if (matches && matches.length > 0) {",
                "            console.log('\\n=== ' + name + ' ===');",
                "            matches.forEach(function(m) {",
                "                console.log(m.teamA.name + ' ' + (m.scoreA || '?') + '-' + (m.scoreB || '?') + ' ' + m.teamB.name + (m.winner ? ' ✅' : ''));",
                "            });",
                "        }",
                "    }",
                "    logRound('Round of 16', b.round_of_16);",
                "    logRound('Quarterfinal', b.quarterfinal);",
                "    logRound('Semifinal', b.semifinal);",
                "    logRound('Final', b.final);",
                "    ",
                "    if (b.champion) {",
                "        console.log('\\n🏆 CHAMPION: ' + b.champion.name + '! 🏆');",
                "    } else {",
                "        console.log('\\nNo champion yet');",
                "    }",
                "});"
              ]
            }
          }]
        }
      ]
    }
  ]
}
