{
  "info": {
    "name": "World Cup Simulator",
    "description": "World Cup Simulator API - Dynamic collection that adapts to actual match IDs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "finalMatchId", "value": "" },
    { "key": "knockoutMatchCount", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth & Reset",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{baseUrl}}/login", "host": ["{{baseUrl}}"], "path": ["login"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
                "if (jsonData.token) {",
                "    pm.collectionVariables.set('token', jsonData.token);",
                "    console.log('Token saved!');",
                "}",
                "pm.test('Login successful', function () {",
                "    pm.response.to.have.status(200);",
                "});"
              ]
            }
          }]
        },
        {
          "name": "Reset Tournament",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/tournament/reset", "host": ["{{baseUrl}}"], "path": ["tournament", "reset"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Reset successful', function () {",
                "    pm.expect(pm.response.code).to.be.oneOf([200, 500]);",
                "    console.log('Reset done');",
                "});"
              ]
            }
          }]
        }
      ]
    },
